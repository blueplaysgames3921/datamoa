{
  "name": "datamoa",
  "version": "0.1.0",
  "description": "Professional Multi-Agent Data Entry Orchestration System",
  "main": "dist/electron/main.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:renderer\" \"npm run dev:electron\"",
    "dev:renderer": "vite",
    "dev:electron": "tsc -p tsconfig.electron.json && electron .",
    "build": "vite build && tsc -p tsconfig.electron.json",
    "start": "electron .",
    "python:dev": "PYTHONPATH=. python3 core/main.py --port 7532",
    "install:python": "pip install -r requirements.txt --break-system-packages",
    "setup": "npm install && npm run install:python",
    "package": "npm run build && electron-builder build",
    "python:dev:win": "set PYTHONPATH=. && python core/main.py --port 7532"
  },
  "dependencies": {
    "electron-store": "^8.1.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "zustand": "^4.5.0",
    "node-fetch": "^3.3.2",
    "form-data": "^4.0.0",
    "ws": "^8.17.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.0.0",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.0.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.0.0",
    "vite": "^5.0.0",
    "@tailwindcss/forms": "^0.5.7",
    "@types/ws": "^8.5.10"
  },
  "build": {
    "appId": "com.datamoa.app",
    "productName": "DataMoA",
    "asar": true,
    "directories": {
      "output": "release",
      "buildResources": "assets"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "core",
        "to": "core",
        "filter": [
          "**/*",
          "!**/__pycache__/**",
          "!**/*.pyc"
        ]
      }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "assets/icon.icns"
    },
    "win": {
      "icon": "assets/icon.ico"
    },
    "linux": {
      "icon": "assets/icon.png",
      "target": [
        "AppImage",
        "deb"
      ]
    }
  }
}